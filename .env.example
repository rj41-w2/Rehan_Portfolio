# Firebase Configuration
# Copy this file to .env and fill in your actual values

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Google Generative AI (Gemini)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# GroQ API Key
VITE_GROQ_API_KEY=your_groq_api_key_here

# Open-router API Key
VITE_OPEN_ROUTER_API_KEY=your_open_router_api_key_here

# Local AI Testing (Ollama)
# Set to "true" to use local Ollama instead of Groq
# Note: Ensure Ollama is running and you have run: ollama pull llama3
VITE_USE_OLLAMA=false

# web3forms (for Contact form)
VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# hCaptcha (for Contact form)
VITE_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key_here
